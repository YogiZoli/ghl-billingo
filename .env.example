# ---- GHL (live now — Voxflow Reputation subaccount) ----
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_PIT_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=m9q9yoqupdLNrlRerXnj

# ---- Billingo (per-tenant; supplied by the client) ----
BILLINGO_BASE_URL=https://api.billingo.hu/v3
BILLINGO_API_KEY=

# ---- Behaviour ----
# Which document date drives the schedule: fulfillment_date | invoice_date | paid_date
ANCHOR_DATE=fulfillment_date
# Days added to the anchor date before the review tag is applied
DELAY_DAYS=1
# Poll cadence in minutes: 10 | 15 | 30 | 60
POLL_INTERVAL_MIN=30
# Tag that starts the GHL "02. Review Request" workflow
REVIEW_ENTRY_TAG=customer
# Repeat customers: remove then re-add the tag so the workflow re-triggers
RETAG_IF_PRESENT=true
# If the invoiced partner isn't in GHL, create the contact (then tag it).
# false = skip and log instead.
CREATE_CONTACT_IF_MISSING=true
# Timezone for all date math
TIMEZONE=Europe/Budapest

# ---- GHL Custom Value overrides (LOCKED onboarding model) ----
# In production Mate sets these per-subaccount as GHL Custom Values; the
# connector reads them at run time and they OVERRIDE the values above:
#   billingo_api_key     -> the client's Billingo key (blank = subaccount inactive)
#   billingo_delay_days  -> overrides DELAY_DAYS
#   billingo_poll_min    -> overrides POLL_INTERVAL_MIN (10/15/30/60)
# The .env values here are just defaults/fallbacks for local runs.

# ---- Storage / crypto ----
# Generate with: python -m app.cli gen-key
FERNET_KEY=
DB_PATH=data/connector.db
